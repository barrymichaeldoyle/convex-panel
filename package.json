{
  "name": "convex-inspect-workspace",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "dev:docs": "pnpm --filter @convex-inspect/docs dev",
    "version-packages": "changeset version",
    "dev:example-react": "pnpm --filter @convex-inspect/example-react dev",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "release": "pnpm build && changeset publish",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
