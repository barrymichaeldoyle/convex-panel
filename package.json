{
  "name": "convex-inspect-workspace",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "ci:check": "pnpm audit --audit-level low && pnpm lint && pnpm knip && pnpm test && pnpm typecheck && pnpm build",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version",
    "dev:docs": "pnpm --filter @convex-inspect/docs dev",
    "dev:example-react": "pnpm --filter @convex-inspect/example-react dev",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check",
    "fallow:check": "fallow --summary",
    "knip": "knip",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "pp": "patch-pulse",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "release": "pnpm build && changeset publish",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "fallow": "^2.64.0",
    "jsdom": "29.1.1",
    "knip": "6.11.0",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "patch-pulse": "4.1.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "overrides": {
      "yaml": "2.8.3"
    }
  },
  "packageManager": "pnpm@10.30.3"
}
