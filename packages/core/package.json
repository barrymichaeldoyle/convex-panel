{
  "name": "convex-inspect",
  "version": "0.2.0",
  "description": "Devtools panel for Convex — inspect queries, mutations, and actions during development",
  "keywords": [
    "convex",
    "devtools",
    "panel",
    "react"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barrymichaeldoyle/convex-inspect.git"
  },
  "homepage": "https://barrymichaeldoyle.github.io/convex-inspect/",
  "bugs": {
    "url": "https://github.com/barrymichaeldoyle/convex-inspect/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react-lazy.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react-lazy.d.ts",
      "import": "./dist/react-lazy.js",
      "require": "./dist/react-lazy.cjs"
    }
  },
  "files": [
    "dist",
    "react",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/react.tsx src/react-lazy.tsx --dts --format esm,cjs --external react --external react-dom --external react/jsx-runtime --clean",
    "dev": "tsup src/index.ts src/react.tsx src/react-lazy.tsx --dts --format esm,cjs --external react --external react-dom --external react/jsx-runtime --watch --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "convex": ">=1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "convex": "^1.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
